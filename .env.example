# ---------------------------------------------------------------------------
# Copy this file to ".env" and fill in your real OpenAI API key.
# This project uses OpenAI everywhere: the graph engine's internal LLM,
# its embeddings, and the LangGraph Generator/Critic agents in the
# verification loop.
# ---------------------------------------------------------------------------

# --- Graph engine's own LLM (used internally for extraction / completions) ---
LLM_API_KEY=
LLM_PROVIDER=openai
LLM_MODEL=openai/gpt-4.1-mini

# --- Embedding model (used for chunk/entity/triplet vectors) ---
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
# EMBEDDING_API_KEY is optional - if unset, falls back to LLM_API_KEY.
# Uncomment if you want to use a different key/account for embeddings:
# EMBEDDING_API_KEY=your_openai_api_key

# --- Required for evidence assembly (triplet-level citation retrieval) ---
# Must be set BEFORE the first ingestion run, or triplet embeddings won't exist.
TRIPLET_EMBEDDING=true

# --- Used directly by the LangGraph Generator/Critic agents ---
# (langchain-openai reads this automatically)
OPENAI_API_KEY=

# --- Storage locations (auto-resolved, no edits needed) ---
# By default, the graph engine stores its SQLite/vector/graph files inside
# your virtualenv's site-packages folder, which is easy to lose track of
# and gets wiped if you recreate the venv. novelgraph/config.py resolves
# SYSTEM_ROOT_DIRECTORY and DATA_ROOT_DIRECTORY to absolute paths anchored
# to THIS project's own folder automatically (<project root>/.cognee_system
# and <project root>/.cognee_data) - no edits needed on a fresh clone.
#
# Uncomment either line below only if you want to override that default
# (e.g. to point at a shared/external location). If set, it must be an
# ABSOLUTE path (relative paths raise an error) - `~` is expanded for you.
# SYSTEM_ROOT_DIRECTORY=/absolute/path/to/storage/.cognee_system
# DATA_ROOT_DIRECTORY=/absolute/path/to/storage/.cognee_data
# COGNEE_SQLITE_PATH=/absolute/path/to/.cognee_system/databases/cognee_db

# --- Optional tuning knobs (see README's Configuration table for the rest) ---
# RESEARCH_CHUNK_SIZE=60000
# TASK_SIMILARITY_THRESHOLD=0.25
# CAPTION_FIGURES=false
# SKIP_COT_SEED=false
# SKIP_INGEST=false
# RESET_GRAPH=false
